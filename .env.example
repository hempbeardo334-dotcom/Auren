# Environment Variables for AUREN Fashion Commerce
# Copy this file to .env.local and fill in your values

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (if using a database in the future)
# DATABASE_URL="postgresql://username:password@localhost:5432/auren"

# Payment Processing (Stripe)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# Email Service (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# Note: notification emails are sent to hempbeardo@gmail.com by default.

# Analytics (Google Analytics, etc.)
# GA_TRACKING_ID=G-XXXXXXXXXX

# AI/ML Services (for fashion recommendations)
# OPENAI_API_KEY=sk-...
# RECOMMENDATION_API_URL=https://api.auren.ai